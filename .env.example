# Printer IP (same Wi‑Fi as this PC). Find on printer: Settings → Device → Network
PRINTER_IP=192.168.1.xxx
# Access code: on printer touchscreen: Settings → LAN Only Mode — copy the code shown there (NOT your Bambu account password)
ACCESS_CODE=your_access_code
# Optional: printer serial (Settings → Device). If set, uses device/SERIAL/report for a more stable connection
# PRINTER_SERIAL=00M09C411500579
# Optional: your PC's LAN IP (so "open on phone" URL is correct)
PC_IP=192.168.1.xxx
PRINTER_SERIAL=